{
  "name": "template-vendas-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
"scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "start": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
